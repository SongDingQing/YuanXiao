# Copy this file to ops/config/yuanxiao.env and fill in private values.
# Placeholder `a` values show the expected shape without exposing a real host.

# Public relay/server identity
YUANXIAO_PUBLIC_BASE_URL=https://a.example.com
YUANXIAO_RELAY_HOST=a.example.com
YUANXIAO_RELAY_SSH_USER=a
YUANXIAO_RELAY_SSH_KEY=/Users/a/.ssh/a_relay_key

# Remote server install paths
YUANXIAO_DEPLOY_DIR=/opt/yuanxiao
YUANXIAO_SYSTEMD_ENV_DIR=/etc/yuanxiao
YUANXIAO_SERVICE_USER=yuanxiao
YUANXIAO_SERVICE_GROUP=yuanxiao

# HTTPS certificate generation
# Use either DNS:a.example.com or IP:a.b.c.d.
YUANXIAO_TLS_COMMON_NAME=a.example.com
YUANXIAO_TLS_SAN=DNS:a.example.com

# Relay runtime
YUANXIAO_HOST=
YUANXIAO_PORT=443
YUANXIAO_HERMES_BRIDGE_URL=http://localhost:18642/api/chat
YUANXIAO_HERMES_BRIDGE_TIMEOUT_SECONDS=900
YUANXIAO_REQUEST_SOCKET_TIMEOUT_SECONDS=960
YUANXIAO_MAX_REQUEST_BYTES=6000000
YUANXIAO_KEEPALIVE_INTERVAL_SECONDS=10
YUANXIAO_TLS_HANDSHAKE_TIMEOUT_SECONDS=5
YUANXIAO_CERT_FILE=/opt/yuanxiao/certs/server.crt
YUANXIAO_KEY_FILE=/opt/yuanxiao/certs/server.key
YUANXIAO_INBOX_FILE=/opt/yuanxiao/data/app_inbox.jsonl
YUANXIAO_MAX_INBOX_MESSAGES=200
YUANXIAO_ADMIN_TOKEN=

# Mac mini bridge / tunnel
YUANXIAO_LOCAL_BRIDGE_DIR=/Users/a/ChangE/yuanxiao-hermes-bridge
YUANXIAO_LOCAL_PYTHON=/Users/a/.hermes/hermes-agent/venv/bin/python
YUANXIAO_LOCAL_SSH_KEY=/Users/a/.ssh/a_relay_key
YUANXIAO_LOCAL_BRIDGE_HOST=localhost
YUANXIAO_LOCAL_BRIDGE_PORT=18765
YUANXIAO_REMOTE_TUNNEL_PORT=18642
YUANXIAO_HERMES_ENV_FILE=/Users/a/.hermes/.env
YUANXIAO_CODEX_HOME=/Users/a/.codex
YUANXIAO_PLAN_STATE_FILE=/Users/a/.yuanxiao/plan-state.json
